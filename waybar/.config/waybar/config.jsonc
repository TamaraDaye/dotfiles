{
  "style": "~/.config/waybar/style.css",
  "layer": "top",
  "position": "top",
  "height": 30,
  "modules-left": ["custom/arch-logo", "hyprland/workspaces"],
  "modules-center": ["mpris"],
  "modules-right": [
    "network",
    "battery",
    "clock#time",
    "clock#date",
    "cpu",
    "temperature",
  ],
  "include": ["~/.config/waybar/modules.jsonc"],
}
