# Profile 1: Docked (Matches when DP-3 AND eDP-1 are connected)
profile {
	output "eDP-2" disable
    output "ASUSTek COMPUTER INC VG259QM M3LMQS145776" enable mode 1920x1080@279.85699 position 0,0

}

# Profile 2: Mobile (Matches when ONLY eDP-1 is connected)
profile {
    output eDP-2 enable mode 2560x1600@240 scale 1.6

    # Force the laptop screen on and reset the scale
    exec hyprctl keyword monitor "eDP-2,2560x1600@240,auto,1.6"
}
